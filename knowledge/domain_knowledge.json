    "false_patterns": {
        "_description": "Issues that LOOK similar on the surface but have different root causes. Prevents AI from making wrong matches.",
        "examples": [
            {
                "symptom": "Overtime hours showing as zero",
                "looks_like": "Pay rule not configured for OT",
                "but_actually_could_be": [
                    "Employee exemption status set incorrectly",
                    "Pay period boundary causing split-week calculation",
                    "Schedule not linked to pay policy",
                    "Effective dating mismatch on policy assignment"
                ]
            },
            {
                "symptom": "Schedule not appearing for employee",
                "looks_like": "Schedule not assigned",
                "but_actually_could_be": [
                    "Employee org unit changed and lost schedule inheritance",
                    "Effective dating gap in schedule assignment",
                    "Schedule template expired",
                    "Caching issue - schedule exists but UI not refreshing"
                ]
            }
        ]
    },

    "environment_notes": {
        "_description": "Environment-specific quirks that affect troubleshooting.",
        "notes": [
            "Production data refresh to staging happens weekly on Sundays",
            "UPDATE: Add your own environment-specific notes here"
        ]
    }
}
